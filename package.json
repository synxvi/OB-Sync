{
  "name": "ob-sync",
  "version": "1.2.3",
  "description": "A simplified sync plugin for Obsidian app with WebDAV and OneDrive support.",
  "scripts": {
    "dev": "node esbuild.config.mjs --watch",
    "build": "tsc -noEmit -skipLibCheck && node esbuild.config.mjs production",
    "format": "npx @biomejs/biome check --write .",
    "clean": "npx rimraf main.js",
    "test": "mocha --import=tsx 'tests/**/*.ts' 'pro/tests/**/*.ts'"
  },
  "browser": {
    "path": "path-browserify",
    "process": "process/browser",
    "stream": "stream-browserify",
    "crypto": "crypto-browserify",
    "url": "url/",
    "util": "util",
    "node:url": "url/",
    "fs": false,
    "vm": false
  },
  "source": "main.ts",
  "keywords": [],
  "author": "",
  "license": "SEE LICENSE IN LICENSE",
  "devDependencies": {
    "@biomejs/biome": "2.4.12",
    "@microsoft/microsoft-graph-types": "^2.43.1",
    "@types/chai": "^5.2.3",
    "@types/chai-as-promised": "^8.0.2",
    "@types/jsdom": "^28.0.1",
    "@types/lodash": "^4.17.24",
    "@types/mime-types": "^3.0.1",
    "@types/mocha": "^10.0.10",
    "@types/mustache": "^4.2.6",
    "@types/node": "^25.6.0",
    "@types/qrcode": "^1.5.6",
    "builtin-modules": "^5.1.0",
    "cross-env": "^10.1.0",
    "dotenv": "^17.4.2",
    "esbuild": "^0.28.0",
    "esbuild-plugin-inline-worker": "^0.1.1",
    "jsdom": "^29.0.2",
    "mocha": "^11.7.5",
    "npm-check-updates": "^21.0.2",
    "obsidian": "^1.12.3",
    "openapi-typescript": "^7.13.0",
    "tslib": "^2.8.1",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3",
    "webdav-server": "^2.6.2"
  },
  "dependencies": {
    "@azure/msal-node": "^5.1.3",
    "@fyears/rclone-crypt": "^0.0.7",
    "@fyears/tsqueue": "^1.0.1",
    "@microsoft/microsoft-graph-client": "^3.0.7",
    "aggregate-error": "^5.0.0",
    "buffer": "^6.0.3",
    "crypto-browserify": "^3.12.1",
    "emoji-regex": "^10.6.0",
    "http-status-codes": "^2.3.0",
    "localforage": "^1.10.0",
    "localforage-getitems": "^1.4.2",
    "localforage-removeitems": "^1.4.0",
    "lodash": "^4.18.1",
    "lucide": "^1.8.0",
    "mustache": "^4.2.0",
    "nanoid": "^5.1.9",
    "node-diff3": "^3.2.0",
    "p-queue": "^9.1.2",
    "path-browserify": "^1.0.1",
    "process": "^0.11.10",
    "qrcode": "^1.5.4",
    "rfc4648": "^1.5.4",
    "rimraf": "^6.1.3",
    "stream-browserify": "^3.0.0",
    "url": "^0.11.4",
    "util": "^0.12.5",
    "webdav": "^5.9.0",
    "xregexp": "^5.1.2"
  }
}
